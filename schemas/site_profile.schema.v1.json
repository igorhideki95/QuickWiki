{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quickwiki.local/schemas/site_profile.schema.v1.json",
  "title": "QuickWiki Site Profile v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "key",
    "default_seed_url",
    "allowed_domains"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "wiki_family": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "key": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "label": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "default_seed_url": {
      "type": "string",
      "format": "uri"
    },
    "allowed_domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_path_prefix": {
      "type": "string"
    },
    "api_path": {
      "type": "string"
    },
    "title_selectors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "content_root_selectors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "category_selectors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "extra_noise_selectors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
